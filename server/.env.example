# Copy file này thành .env:  cp .env.example .env  (Windows: copy .env.example .env)

# Bộ phân loại extension dùng qua WebSocket: "qwen" hoặc bỏ trống = phobert
CLASSIFIER=qwen

# URL model service Qwen LoRA
MODEL_SERVICE_QWEN_URL=http://localhost:3002

# URL model service PhoBERT (chỉ dùng khi CLASSIFIER không phải qwen)
MODEL_SERVICE_URL=http://localhost:3000

PORT=5000
NODE_ENV=development
